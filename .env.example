# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Required ---
OPENAI_API_KEY=
EXA_API_KEY=

# --- Phase 4: job postings via RapidAPI / JSearch (optional for now) ---
RAPIDAPI_KEY=
JSEARCH_COUNTRY=us
JSEARCH_MAX_JOBS=5
JSEARCH_MAX_CONCURRENCY=2  # bound for JSearch calls, separate from MAX_WORKERS

# --- Phase 8: Redis cache (optional; defaults to local) ---
REDIS_URL=redis://localhost:6379/0

# --- Optional model overrides ---
COMPANY_FINDER_MODEL=gpt-5.4-nano
CONTACT_FINDER_MODEL=gpt-4o
RESEARCH_MODEL=gpt-5.4-nano
EMAIL_WRITER_MODEL=gpt-5.4-nano

# --- Optional tuning ---
MAX_WORKERS=6

# --- Email evaluation (Phase 4b deterministic gate) ---
EMAIL_MIN_WORDS=40
EMAIL_MAX_WORDS=200

# --- LLM faithfulness judge (Phase 4c) ---
# Paid; runs only on drafts that pass the deterministic gate. Off by default.
ENABLE_LLM_JUDGE=false
JUDGE_MODEL=gpt-4o
JUDGE_MAX_CONCURRENCY=2
ENABLE_REPAIR=true  # one bounded rewrite when the judge finds an email unfaithful

# --- Behavior / safety ---
# Enable agno agent debug logging (prints prompts/responses incl. PII). Local dev only.
DEBUG_AGENTS=false
# Draft outreach to inferred/guessed emails. Off by default (deliverability/privacy risk).
INCLUDE_INFERRED_CONTACTS=false
