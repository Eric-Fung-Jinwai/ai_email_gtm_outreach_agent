# Copy to .env and fill in. .env is gitignored — never commit real keys.

# --- Required ---
OPENAI_API_KEY=
EXA_API_KEY=

# --- Phase 4: job postings via RapidAPI / JSearch (optional for now) ---
RAPIDAPI_KEY=
JSEARCH_COUNTRY=us
JSEARCH_MAX_JOBS=5
JSEARCH_MAX_CONCURRENCY=2  # bound for JSearch calls, separate from MAX_WORKERS

# --- Phase 6: campaign history + contact cooldown ---
# Separate application DB (NOT the agno session DB). Lives under gitignored tmp/.
APP_DB_PATH=tmp/campaigns.db
# Don't re-contact a company we generated outreach for within this many days.
ENABLE_CONTACT_SUPPRESSION=true
CONTACT_COOLDOWN_DAYS=30
# Cooldown scope: "user" = each account's own history; "global" = across ALL
# accounts (cross-tenant dedup). There is no org/team model, so "global" is truly
# global — set it knowingly.
COOLDOWN_SCOPE=user

# --- Multi-user web app (FastAPI frontend: `uvicorn server.main:app`) ---
# Secure-by-default: with ENVIRONMENT unset it is treated as PRODUCTION —
# HTTPS-only cookies and a strong SESSION_SECRET (>=32 chars) are REQUIRED, so a
# copied template can't silently run insecurely. Generate a secret with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Comma-separated public origins allowed to POST (CSRF). Set to your real URL(s)
# behind a proxy, e.g. https://outreach.example.com . Empty = match request host.
TRUSTED_ORIGINS=
# Cancel a single outreach run after this many seconds (hung-provider safety).
PIPELINE_TIMEOUT_SECONDS=300
#
# LOCAL DEVELOPMENT ONLY — uncomment to relax cookie security and the secret rule.
# Never set this in a real deployment.
#   ENVIRONMENT=development

# --- Reserved for future multi-user caching (NOT wired — Redis was descoped) ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_RESEARCH=604800  # 7 days
CACHE_TTL_CONTACTS=259200  # 3 days

# --- Optional model overrides ---
COMPANY_FINDER_MODEL=gpt-5.4-nano
CONTACT_FINDER_MODEL=gpt-4o
RESEARCH_MODEL=gpt-5.4-nano
EMAIL_WRITER_MODEL=gpt-5.4-nano

# --- Optional tuning ---
MAX_WORKERS=6
API_MAX_RETRIES=3       # retry attempts for transient agent/API errors
API_RETRY_WAIT=0.5      # exponential backoff multiplier (seconds)

# --- Email evaluation (Phase 4b deterministic gate) ---
EMAIL_MIN_WORDS=40
EMAIL_MAX_WORDS=200

# --- LLM faithfulness judge (Phase 4c) ---
# Paid; runs only on drafts that pass the deterministic gate. Off by default.
ENABLE_LLM_JUDGE=false
JUDGE_MODEL=gpt-4o
JUDGE_MAX_CONCURRENCY=2
ENABLE_REPAIR=true  # one bounded rewrite when the judge finds an email unfaithful

# --- Observability ---
LOG_LEVEL=INFO

# --- Behavior / safety ---
# Enable agno agent debug logging (prints prompts/responses incl. PII). Local dev only.
DEBUG_AGENTS=false
# Draft outreach to inferred/guessed emails. Off by default (deliverability/privacy risk).
INCLUDE_INFERRED_CONTACTS=false
